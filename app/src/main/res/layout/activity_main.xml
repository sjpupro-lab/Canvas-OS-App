<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <!-- Logo -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="◆ CANVAS OS"
        android:textColor="#39D353"
        android:textSize="32sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spatial Operating System"
        android:textColor="#8B949E"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/tvLogo"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.8"
        android:textColor="#484F58"
        android:textSize="12sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Menu Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLauncher"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="◆  BOOT CANVASOS"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:backgroundTint="#238636"
            android:layout_marginBottom="16dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCli"
            android:layout_width="280dp"
            android:layout_height="52dp"
            android:text="▸  CLI Shell"
            android:textColor="#C9D1D9"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:backgroundTint="#21262D"
            android:layout_marginBottom="8dp"
            app:cornerRadius="8dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTervas"
            android:layout_width="280dp"
            android:layout_height="52dp"
            android:text="▸  Tervas Terminal"
            android:textColor="#C9D1D9"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:backgroundTint="#21262D"
            android:layout_marginBottom="8dp"
            app:cornerRadius="8dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            android:layout_width="280dp"
            android:layout_height="52dp"
            android:text="▸  Run Tests (160)"
            android:textColor="#8B949E"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:backgroundTint="#21262D"
            app:cornerRadius="8dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="sjpupro-lab | Busan, South Korea"
        android:textColor="#484F58"
        android:textSize="11sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
