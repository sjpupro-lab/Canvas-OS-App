<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <!-- Canvas View -->
    <com.sjpupro.canvasos.CanvasView
        android:id="@+id/canvasView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCellInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cell(-,-)"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#80000000" />

    <!-- Control Bar -->
    <HorizontalScrollView
        android:id="@+id/controlBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/timelineBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#161B22"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnMode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ABGR" android:textColor="#39D353" android:textSize="12sp" android:fontFamily="monospace" android:minWidth="56dp" android:minHeight="36dp" android:layout_marginEnd="4dp" android:backgroundTint="#21262D" />
            <Button android:id="@+id/btnGate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gate" android:textColor="#F85149" android:textSize="12sp" android:fontFamily="monospace" android:minWidth="56dp" android:minHeight="36dp" android:layout_marginEnd="4dp" android:backgroundTint="#21262D" />
            <Button android:id="@+id/btnSnapshot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Snap" android:textColor="#58A6FF" android:textSize="12sp" android:fontFamily="monospace" android:minWidth="56dp" android:minHeight="36dp" android:layout_marginEnd="4dp" android:backgroundTint="#21262D" />
            <Button android:id="@+id/btnHash" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hash" android:textColor="#D29922" android:textSize="12sp" android:fontFamily="monospace" android:minWidth="56dp" android:minHeight="36dp" android:layout_marginEnd="4dp" android:backgroundTint="#21262D" />
            <Button android:id="@+id/btnTerminal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Term" android:textColor="#8B949E" android:textSize="12sp" android:fontFamily="monospace" android:minWidth="56dp" android:minHeight="36dp" android:layout_marginEnd="4dp" android:backgroundTint="#21262D" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Timeline Bar -->
    <LinearLayout
        android:id="@+id/timelineBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#21262D"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btnRewind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RW" android:textColor="#D29922" android:textSize="16sp" android:minWidth="56dp" android:minHeight="48dp" android:layout_marginEnd="8dp" android:backgroundTint="#21262D" />
        <Button android:id="@+id/btnPlay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLAY" android:textColor="#39D353" android:textSize="16sp" android:minWidth="56dp" android:minHeight="48dp" android:layout_marginEnd="8dp" android:backgroundTint="#21262D" />
        <Button android:id="@+id/btnForward" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FF" android:textColor="#D29922" android:textSize="16sp" android:minWidth="56dp" android:minHeight="48dp" android:layout_marginEnd="8dp" android:backgroundTint="#21262D" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
