<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <!-- Canvas View (실시간 시각화) -->
    <com.sjpupro.canvasos.CanvasView
        android:id="@+id/canvasView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cell Info Bar -->
    <TextView
        android:id="@+id/tvCellInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cell(-,-)"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#80000000" />

    <!-- Control Bar -->
    <HorizontalScrollView
        android:id="@+id/controlBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/timelineBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#161B22"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <!-- 시각화 모드 -->
            <Button
                android:id="@+id/btnMode"
                style="@style/QuickBtn"
                android:text="ABGR"
                android:textColor="#39D353" />

            <!-- 게이트 오버레이 -->
            <Button
                android:id="@+id/btnGate"
                style="@style/QuickBtn"
                android:text="Gate"
                android:textColor="#F85149" />

            <!-- 스냅샷 -->
            <Button
                android:id="@+id/btnSnapshot"
                style="@style/QuickBtn"
                android:text="Snap"
                android:textColor="#58A6FF" />

            <!-- 해시 -->
            <Button
                android:id="@+id/btnHash"
                style="@style/QuickBtn"
                android:text="Hash"
                android:textColor="#D29922" />

            <!-- 터미널 전환 -->
            <Button
                android:id="@+id/btnTerminal"
                style="@style/QuickBtn"
                android:text="Term"
                android:textColor="#8B949E" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Timeline Bar (타임라인 제어) -->
    <LinearLayout
        android:id="@+id/timelineBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#21262D"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRewind"
            style="@style/DpadBtn"
            android:text="⏪"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnPlay"
            style="@style/DpadBtn"
            android:text="▶"
            android:textColor="#39D353"
            android:textSize="22sp" />

        <Button
            android:id="@+id/btnForward"
            style="@style/DpadBtn"
            android:text="⏩"
            android:textSize="18sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
