<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CanvasOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="Theme.CanvasOS.Terminal" parent="Theme.CanvasOS">
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="QuickBtn" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="backgroundTint">@color/bg_tertiary</item>
    </style>

    <style name="DpadBtn" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_yellow</item>
        <item name="android:textSize">20sp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="backgroundTint">@color/bg_tertiary</item>
    </style>
</resources>
